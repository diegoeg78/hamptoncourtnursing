server {
    server_name hamptoncourtnursing.reliableits.net;

    root /home/diego/hamptoncourtnursing/artifacts/hampton-court/dist/public;
    index index.html;

    # Serve the React SPA — send all routes to index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy contact form and API requests to the Node API server
    location /api/ {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_cache_bypass $http_upgrade;
    }

    # Cache static assets aggressively
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    listen 443 ssl;
    listen [::]:443 ssl;
    # SSL managed by Certbot — run: sudo certbot --nginx -d hamptoncourtnursing.reliableits.net
    # ssl_certificate /etc/letsencrypt/live/hamptoncourtnursing.reliableits.net/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/hamptoncourtnursing.reliableits.net/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = hamptoncourtnursing.reliableits.net) {
        return 301 https://$host$request_uri;
    }

    listen 80;
    listen [::]:80;
    server_name hamptoncourtnursing.reliableits.net;
    return 404;
}
